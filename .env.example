OPENAI_API_KEY=your-key-here
SECRET_KEY=change-me-to-a-random-string

# Default admin account (created on first run if no users exist)
# DEFAULT_ADMIN_EMAIL=admin@localhost
# DEFAULT_ADMIN_PASSWORD=admin

# Database — leave empty for SQLite (default), set for PostgreSQL
# DATABASE_URL=postgresql://sememes:sememes_dev@localhost:5432/sememes

# Storage — "local" (default) or "minio"
# STORAGE_BACKEND=minio
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_SECURE=false
# MINIO_BUCKET_LIBRARY=sememes-library
# MINIO_BUCKET_ATTACHMENTS=sememes-attachments
# MINIO_BUCKET_UPLOADS=sememes-uploads

# Redis (optional)
# REDIS_URL=redis://localhost:6379/0
